          "targetX": 8,
          "targetY": 8
        },
        {
          "type": "say",
          "actorId": "kenelm",
          "text": "The obsidian here is aged by the sun. It is the perfect womb for the vitriolic soul."
        },
        {
          "type": "emote",
          "actorId": "kenelm",
          "emotion": "idea"
        },
